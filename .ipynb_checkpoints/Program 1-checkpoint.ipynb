   "source": [
    "# Problem 1:  Write a Python program to swap two variables."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "4452bdb6-b983-47ce-8f8c-fbbc24a34125",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter first value:  10\n",
      "Enter second value:  20\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "After swapping:\n",
      "First value = 20\n",
      "Second value = 10\n"
     ]
    }
   ],
   "source": [
    "a = input(\"Enter first value: \")\n",
    "b = input(\"Enter second value: \")\n",
    "\n",
    "a, b = b, a\n",
    "\n",
    "print(\"After swapping:\")\n",
    "print(\"First value =\", a)\n",
    "print(\"Second value =\", b)"
   ]
  },
